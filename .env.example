# =============================================================================
# CloudOS-RL Environment Variables
# =============================================================================
# SETUP:
#   cp .env.example .env
#   Edit .env with your actual values
#   Never commit .env to git
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
CLOUDOS_DEBUG=false
CLOUDOS_API_PORT=8000
CLOUDOS_LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Kafka
# -----------------------------------------------------------------------------
CLOUDOS_KAFKA_BOOTSTRAP=localhost:9092

# -----------------------------------------------------------------------------
# AWS
# -----------------------------------------------------------------------------
CLOUDOS_AWS_REGION=us-east-1

# Use 'aws configure' to set credentials — do NOT hardcode keys here.
# IAM permissions required for Module G:
#   pricing:GetProducts              <- AWS Pricing API (on-demand rates)
#   ec2:DescribeSpotPriceHistory     <- Live spot prices
#   ce:GetCostAndUsage               <- Cost Explorer (actual spend)
#   ce:GetDimensionValues            <- Cost Explorer dimensions
AWS_PROFILE=default

# -----------------------------------------------------------------------------
# Model Paths
# -----------------------------------------------------------------------------
CLOUDOS_MODEL_PATH=models/best/best_model
CLOUDOS_VECNORM_PATH=models/vec_normalize.pkl
CLOUDOS_CONFIG_PATH=config/settings.yaml

# -----------------------------------------------------------------------------
# Carbon Intensity API (Module G)
# -----------------------------------------------------------------------------
# Electricity Maps v3 API for real-time grid carbon data.
# Free tier covers real-time data for 16+ regions.
# Without this key: static Ember Climate 2023 annual averages are used.
# Static values are still valid for RL training — live data improves inference accuracy.
# Get free key: https://www.electricitymaps.com/free-tier
ELECTRICITY_MAPS_API_KEY=

# -----------------------------------------------------------------------------
# Data Pipeline Overrides (optional — defaults come from config/settings.yaml)
# -----------------------------------------------------------------------------
# Uncomment to override without editing settings.yaml
# CLOUDOS_DATA_PIPELINE_PRICING_REFRESH_SEC=3600
# CLOUDOS_DATA_PIPELINE_CARBON_REFRESH_SEC=900
# CLOUDOS_DATA_PIPELINE_CUR_REFRESH_SEC=3600
# CLOUDOS_DATA_PIPELINE_ANOMALY_THRESHOLD_PCT=50.0